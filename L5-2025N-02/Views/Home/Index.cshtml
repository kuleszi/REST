@model IEnumerable<L5_2025N_02.Controllers.Dtos.Auctions.AuctionResponse>

<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <title>Dostępne aukcje</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootswatch/5.3.3/morph/bootstrap.min.css" />
</head>
<body class="bg-light">
    <div class="container mt-5">
        <h1 class="mb-4 text-center">Aktualne aukcje</h1>
        
        <table class="table table-hover shadow-sm bg-white rounded">
            <thead class="table-primary">
                <tr>
                    <th>Tytuł</th>
                    <th>Kategoria</th>
                    <th>Status</th>
                    <th>Opis</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><strong>@item.Title</strong></td>
                        <td>@item.Category</td>
                        <td><span class="badge bg-info">@item.Status</span></td>
                        <td>@item.Description</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</body>
</html>